# 高德地图 Web 服务 Key，用于地点解析。
VITE_AMAP_KEY=

# API 服务配置。
API_PORT=4174
DATABASE_PATH=data/class-assistant.sqlite
APP_URL=http://127.0.0.1:5173

# 登录会话与邮箱验证码配置。
LOGIN_CODE_MINUTES=10
SESSION_DAYS=30

# 考试提醒配置：距离考试还有这些天数时发送邮件。
REMINDER_DAYS_BEFORE=7,3,1
REMINDER_SCAN_MINUTES=60

# 邮件发送配置。
# 未配置 RESEND_API_KEY 时，邮件会输出到 npm run api 的终端，方便本地调试。
RESEND_API_KEY=
MAIL_FROM=课表助手 <no-reply@example.com>
